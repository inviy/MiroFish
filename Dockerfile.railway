FROM python:3.12-slim

WORKDIR /app

# Install only production dependencies (no torch/camel-ai)
COPY backend/requirements-prod.txt .
RUN pip install --no-cache-dir -r requirements-prod.txt

# Copy backend source
COPY backend/ ./backend/
COPY .env* ./

WORKDIR /app/backend

EXPOSE 5001

CMD ["python", "run.py"]
