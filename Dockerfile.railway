FROM python:3.12-slim

# Unbuffered output so logs appear in Railway immediately
ENV PYTHONUNBUFFERED=1
ENV FLASK_DEBUG=false

WORKDIR /app

# Install only production dependencies (no torch/camel-ai)
COPY backend/requirements-prod.txt .
RUN pip install --no-cache-dir -r requirements-prod.txt

# Copy backend source
COPY backend/ ./backend/

WORKDIR /app/backend

CMD ["bash", "-c", "echo '=== ENV CHECK ===' && echo LLM_API_KEY=${LLM_API_KEY:0:10}... && echo ZEP_API_KEY=${ZEP_API_KEY:0:10}... && python run.py"]
