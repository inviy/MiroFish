# ===== MiroFish Core LLM =====
# Supports any OpenAI-compatible API (OpenAI, Qwen, etc.)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== Zep Cloud (Knowledge Graph) =====
# Free tier available: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM (Optional, for faster report generation) =====
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== MiroFish Predictor (Polymarket Pipeline) =====
# Polymarket CLOB API key (from https://polymarket.com)
POLYMARKET_API_KEY=your_polymarket_api_key_here
# Wallet private key for placing actual orders (optional, dry-run works without)
POLYMARKET_PRIVATE_KEY=your_private_key_here
# Funded wallet address for portfolio tracking
POLYMARKET_WALLET_ADDRESS=your_wallet_address_here

# ===== Domain Data APIs (Optional, improves prediction quality) =====
# The Odds API for sports betting lines: https://the-odds-api.com (free tier available)
ODDS_API_KEY=your_odds_api_key_here
# Alpha Vantage for financial data: https://alphavantage.co (free tier available)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here